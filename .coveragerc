[run]
# Source code to measure coverage for
source = src/vgnc_internal_orm

# Omit test files and common exclusions
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */site-packages/*
    */dist/*
    */build/*
    */migrations/*
    */alembic/*
    */setup.py
    */conftest.py

# Branch coverage for more comprehensive testing
branch = True

# Enable parallel execution for faster coverage collection
parallel = False

# Data file location
data_file = .coverage

[report]
# Exclude lines matching these patterns from coverage calculation
exclude_lines =
    # Have to re-enable the standard pragma
    pragma: no cover

    # Don't complain about missing debug-only code:
    if self.debug:
    if __name__ == "__main__":
    if TYPE_CHECKING:

    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError
    raise ImportError

    # Don't complain if tests don't hit __repr__ methods
    def __repr__
    def __str__

    # Don't complain if tests don't hit abstract methods
    @abstractmethod
    @abc.abstractmethod

    # Don't complain if tests don't hit type checking code
    if False:
    if 0:
    if __debug__:

    # Don't complain about docstring examples
    >>>
    ...

    # Don't complain about error handling paths that are rarely executed
    except ImportError:
    except ModuleNotFoundError:
    except ValueError:
    except TypeError:
    except KeyError:
    except AttributeError:

    # Don't complain about class definitions that are only used for type hints
    class .*\(Protocol\):
    class .*\(ABC\):
    class .*Interface:

    # Don't complain about method overloads
    @overload

    # Don't complain about property setters that are rarely used
    @.*\.setter

# Show missing lines in terminal output
show_missing = True

# Precision for percentage coverage
precision = 2

# Sort files by name for consistent output
sort = Name

# Skip covered files completely
skip_covered = False

# Skip empty files
skip_empty = True

[html]
# HTML report directory
directory = htmlcov

# Show the source code in the HTML report
show_contexts = True

# Include a link to the source code in the HTML report
extra_css =

[xml]
# XML output file for CI integration
output = coverage.xml

[json]
# JSON output for programmatic processing
output = coverage.json

show_contexts = True