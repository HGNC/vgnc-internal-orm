# VGNC ORM Configuration Environment Variables
# Copy this file to .env and update with your values

# Database Configuration
# For Alembic migrations, you can use DATABASE_URL instead of individual settings
# DATABASE_URL=sqlite:///vgnc_orm.db
# DATABASE_URL=postgresql://username:password@localhost:5432/vgnc_database
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/vgnc_database

# Individual database settings (used by application)
DATABASE__DRIVER=postgresql
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__USERNAME=your_username
DATABASE__PASSWORD=your_password
DATABASE__DATABASE=your_database
DATABASE__SCHEMA=public

# Database Connection Pool Settings
DATABASE__POOL__POOL_SIZE=5
DATABASE__POOL__MAX_OVERFLOW=10
DATABASE__POOL__POOL_TIMEOUT=30
DATABASE__POOL__POOL_RECYCLE=3600
DATABASE__POOL__POOL_PRE_PING=true

# SSL Configuration (optional)
# DATABASE__SSL_MODE=require
# DATABASE__SSL_CERT=/path/to/cert.crt
# DATABASE__SSL_KEY=/path/to/key.key
# DATABASE__SSL_CA=/path/to/ca.crt

# Additional Database Settings
DATABASE__CONNECT_TIMEOUT=10
DATABASE__QUERY_TIMEOUT=
DATABASE__ISOLATION_LEVEL=
DATABASE__ECHO=false

# Application Settings
APP_NAME=VGNC ORM
VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# API Settings (if applicable)
API_HOST=0.0.0.0
API_PORT=8000

# Cache Settings (optional)
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# API Keys for Task Master (Optional)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...